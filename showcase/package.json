{
  "name": "@demeta/showcase",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base=/demeta-frontend/ && node scripts/prepare-pages.mjs",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "npm run build && playwright test",
    "audit:lighthouse": "node scripts/lighthouse-evidence.mjs",
    "audit:evidence": "node scripts/audit-evidence.mjs",
    "verify:evidence-bindings": "node scripts/verify-evidence-bindings.mjs",
    "capture": "node scripts/capture.mjs"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  }
}
